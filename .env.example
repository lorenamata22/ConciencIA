# ── Banco de dados ──────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/conciencia
# Banco temporário usado pelo Prisma Migrate para validar migrations (shadow)
SHADOW_DATABASE_URL=postgresql://user:password@localhost:5432/conciencia_shadow

# ── JWT ─────────────────────────────────────────────
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# ── IA (texto) ──────────────────────────────────────
AI_PROVIDER=google
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
# Anthropic — adapter futuro, não usado nesta etapa
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Voyage AI (embeddings) ──────────────────────────
VOYAGE_API_KEY=
VOYAGE_EMBEDDING_MODEL=voyage-3

# ── Storage ─────────────────────────────────────────
STORAGE_PROVIDER=s3                  # s3 | azure | local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=
AWS_S3_ENDPOINT=
AWS_S3_PUBLIC_URL=
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=

# ── Filas ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379
QUEUE_INGESTION=rag-ingestion

# ── Email (Resend) ──────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=

# ── App ─────────────────────────────────────────────
NODE_ENV=development
BACKEND_PORT=3001
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
